#!/usr/bin/env bash
#
# Build a custom plushie binary with the sparkline extension compiled in.
#
# Requires:
#   - Rust toolchain (rustc >= 1.92)
#
# Usage:
#   bin/build            # debug build
#   bin/build --release  # optimised build

set -euo pipefail
cd "$(dirname "$0")/.."

RELEASE=""
PROFILE="debug"
for arg in "$@"; do
  case "$arg" in
    --release) RELEASE="--release"; PROFILE="release" ;;
    *) echo "Unknown argument: $arg" >&2; exit 1 ;;
  esac
done

BUILD_DIR="_build/custom_binary"
mkdir -p "$BUILD_DIR/src"

SPARKLINE_CRATE="$(pwd)/native/sparkline"

# Generate Cargo.toml using published crates
cat > "$BUILD_DIR/Cargo.toml" <<EOF
[package]
name = "sparkline-dashboard-plushie"
version = "0.1.0"
edition = "2024"

[dependencies]
plushie-ext = "0.5.0"
plushie-renderer = "0.5.0"
sparkline = { path = "$SPARKLINE_CRATE" }
EOF

# Generate main.rs
cat > "$BUILD_DIR/src/main.rs" <<'EOF'
fn main() -> plushie_ext::iced::Result {
    let builder = plushie_ext::app::PlushieAppBuilder::new()
        .extension(sparkline::SparklineExtension::new());
    plushie_renderer::run(builder)
}
EOF

echo "Building custom binary ($PROFILE)..."
cargo build $RELEASE --manifest-path "$BUILD_DIR/Cargo.toml"

# Install
BINARY="$BUILD_DIR/target/$PROFILE/sparkline-dashboard-plushie"
INSTALL_DIR="build/plushie/bin"
mkdir -p "$INSTALL_DIR"
cp "$BINARY" "$INSTALL_DIR/sparkline-dashboard-plushie"

echo "Installed: $INSTALL_DIR/sparkline-dashboard-plushie"
